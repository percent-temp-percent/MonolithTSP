<controls:FancyWindow xmlns="https://spacestation14.io"
                           xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                           Title="{Loc 'poi-capture-console-window-title'}"
                           MinSize="280 220">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" Margin="4 4 4 4">
        <Label Name="CaptureSectionTitle" Text="{Loc 'iff-console-capture-section-title'}" StyleClasses="LabelSubText" />
        <PanelContainer MinHeight="2" />
        <RichTextLabel Name="CaptureOwnerLabel" />
        <RichTextLabel Name="CaptureAttackerLabel" />
        <Label Name="CaptureByLabel" Text="{Loc 'iff-console-capture-by-label'}" />
        <Label Name="CaptureTimerLabel" Text="{Loc 'iff-console-capture-timer-idle'}" />
        <BoxContainer Orientation="Horizontal">
            <Button Name="CaptureStartButton" Text="{Loc 'iff-console-capture-start'}" />
            <Button Name="CaptureInterruptButton" Text="{Loc 'iff-console-capture-interrupt'}" />
        </BoxContainer>
        <BoxContainer Name="TransferSection" Orientation="Vertical">
            <Label Name="TransferCompanyLabel" Text="{Loc 'iff-console-transfer-company-label'}" />
            <OptionButton Name="TransferCompanyOption" MinWidth="220" />
            <Button Name="TransferOwnershipButton" Text="{Loc 'iff-console-transfer-submit'}" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
