### Examine

# Shown when examining the turbine.
turbine-spinning-0 = Лопасти не вращаются.
turbine-spinning-1 = Лопасти вращаются медленно.
turbine-spinning-2 = Лопасти вращаются.
turbine-spinning-3 = Лопасти вращаются быстро.
turbine-spinning-4 = [color=red]Лопасти вращаются вне контроля![/color]

turbine-damaged-0 = Похоже, находится в хорошем состоянии.[/color]
turbine-damaged-1 = Турбина выглядит слегка изношенной.[/color]
turbine-damaged-2 = [color=yellow]Турбина выглядит сильно повреждённой.[/color]
turbine-damaged-3 = [color=orange]Критические повреждения![/color]

turbine-ruined = [color=red]Полностью сломано![/color]

### Popups

# Shown when an event occurs
turbine-overheat = {$owner} активирует аварийный сброс перегрева!
turbine-explode = {$owner} разрывается на части!

# Shown when damage occurs
turbine-spark = {$owner} начинает искрить!
turbine-spark-stop = {$owner} перестаёт искрить.
turbine-smoke = {$owner} начинает дымиться!
turbine-smoke-stop = {$owner} перестаёт дымиться.

# Shown during repairs
turbine-repair-ruined = {$owner} перестаёт дымиться.
turbine-repair = Вы устраняете часть повреждений {$target} с помощью {$tool}.
turbine-no-damage = На {$target} нет повреждений для ремонта с помощью {$tool}.
turbine-show-damage = Прочность лопастей {$health}, макс. прочность {$healthMax}.

# Anchoring warnings
turbine-unanchor-warning = Нельзя открепить газовую турбину, пока она вращается!
turbine-anchor-warning = Недопустимая позиция для закрепления.

