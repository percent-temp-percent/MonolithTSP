### Messages
reactor-smoke-start-message = ОПАСНОСТЬ!: {$owner} достиг опасной рабочей температуры! Текущая температура: {$temperature}K. Требуется немедленное вмешательство!
reactor-smoke-stop-message = {$owner} вернулся к номинальной рабочей температуре.
reactor-fire-start-message = ПРЕДУПРЕЖДЕНИЕ! ПРЕДУПРЕЖДЕНИЕ!: {$owner} в критическом режиме работы! Температура: {$temperature}K. Расплавление активной зоны неизбежно!
reactor-fire-stop-message = {$owner} вернулся к номинальной рабочей температуре. Расплавление активной зоны предотвращено.

reactor-temperature-dangerous-message = {$owner} находится на опасной температуре: {$temperature}K.
reactor-temperature-critical-message = {$owner} находится на критической температуре: {$temperature}K.
reactor-temperature-cooling-message = {$owner} охлаждается: {$temperature}K.

reactor-melting-announcement = РАСПЛАВЛЕНИЕ АКТИВНОЙ ЗОНЫ РЕАКТОРА НЕИЗБЕЖНО! РЕКОМЕНДУЕТСЯ НЕМЕДЛЕННАЯ ЭВАКУАЦИЯ!
reactor-melting-announcement-sender = ЯДЕРНАЯ ТРЕВОГА

reactor-meltdown-announcement = РАСПЛАВЛЕНИЕ АКТИВНОЙ ЗОНЫ РЕАКТОРА НАЧАЛОСЬ! ТРЕБУЕТСЯ НЕМЕДЛЕННАЯ ЭВАКУАЦИЯ!
reactor-meltdown-announcement-sender = РАСПЛАВЛЕНИЕ АКТИВНОЙ ЗОНЫ

